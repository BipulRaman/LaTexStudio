{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LaTeX Studio",
  "version": "0.1.0",
  "identifier": "com.latexstudio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LaTeX Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "backgroundColor": "#0f1115",
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/**/*"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BipulRaman/LaTexStudio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxOTkyM0Y1RjBGNUI3RjkKUldUNXQvWHc5U09aSWNDbTJyenJvVXRPdm9yMkw3Q1JsQTNmNytOaXJhNnNNa0pCUlNNaUtkN1YK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
